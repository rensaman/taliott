generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InviteMode {
  email_invites
  shared_link
}

enum EventStatus {
  open
  locked
  finalized
}

enum AvailabilityState {
  yes
  maybe
  no
  neutral
}

enum TravelMode {
  walking
  cycling
  driving
  transit
}

model Event {
  id               String      @id @default(uuid())
  name             String
  organizerEmail   String
  adminToken       String      @unique @default(uuid())
  inviteMode       InviteMode  @default(email_invites)
  joinToken        String?     @unique
  dateRangeStart   DateTime
  dateRangeEnd     DateTime
  timeRangeStart   Int         @default(480)
  timeRangeEnd     Int         @default(1320)
  timezone         String      @default("UTC")
  venueType        String?
  deadline         DateTime
  status           EventStatus @default(open)
  finalSlotId      String?
  finalVenueId     String?
  finalVenueName   String?
  finalVenueAddress String?
  lang             String      @default("en")
  createdAt        DateTime    @default(now())

  slots            Slot[]
  participants     Participant[]
  venues           Venue[]
}

model Participant {
  id            String         @id @default(uuid())
  eventId       String
  email         String
  name          String?
  latitude      Float?
  longitude     Float?
  addressLabel  String?
  travelMode    TravelMode     @default(transit)
  respondedAt   DateTime?

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  availability  Availability[]

  @@unique([eventId, email])
}

model Slot {
  id        String         @id @default(uuid())
  eventId   String
  startsAt  DateTime
  endsAt    DateTime

  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  availability Availability[]
}

model Availability {
  id            String            @id @default(uuid())
  participantId String
  slotId        String
  state         AvailabilityState @default(neutral)
  updatedAt     DateTime          @updatedAt

  participant   Participant       @relation(fields: [participantId], references: [id], onDelete: Cascade)
  slot          Slot              @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([participantId, slotId])
}

model Venue {
  id         String  @id @default(uuid())
  eventId    String
  externalId String
  venueType  String
  name       String
  latitude   Float
  longitude  Float
  rating     Float?
  distanceM  Int?
  website    String?
  address    String?

  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, externalId, venueType])
}

model RouteCache {
  id          String   @id @default(uuid())
  fromLat     Float
  fromLng     Float
  toLat       Float
  toLng       Float
  mode        String
  durationSec Int
  createdAt   DateTime @default(now())

  @@unique([fromLat, fromLng, toLat, toLng, mode])
}

model Feedback {
  id        String   @id @default(uuid())
  score     Int
  comment   String?
  context   String
  createdAt DateTime @default(now())
}
