DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taliott_dev"

# SMTP — point at Mailpit for local dev, a transactional service (Resend, Postmark) for prod
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="taliott <noreply@taliott.app>"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# Base URL used in participant invite links
APP_BASE_URL="http://localhost:3000"

# OpenRouteService API key for travel-time-weighted centroid (Weiszfeld algorithm).
# Free tier: 500 req/day — sufficient for most usage thanks to DB-backed RouteCache.
# Without this key the centroid falls back to Euclidean (haversine) distances.
# Get a free key at: https://openrouteservice.org
# ORS_API_KEY="your-key-here"
