DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taliott_dev"

# SMTP — point at Mailpit for local dev, a transactional service (Resend, Postmark) for prod
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="taliott <noreply@taliott.app>"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# Base URL used in participant invite links
APP_BASE_URL="http://localhost:3000"

# OpenRouteService API key — used for walking/cycling/driving travel-time centroid.
# Free tier: 500 req/day — sufficient for most usage thanks to DB-backed RouteCache.
# Without this key those modes fall back to Euclidean (haversine) distances.
# Get a free key at: https://openrouteservice.org
# ORS_API_KEY="your-key-here"

# OpenTripPlanner base URL — used for transit (bus/metro) travel-time centroid.
# In Docker Compose this is set automatically to http://otp:8080.
# For local dev outside Docker: run `docker compose up otp` and leave this unset
# (defaults to http://localhost:8080).
# OTP_BASE_URL="http://localhost:8080"
